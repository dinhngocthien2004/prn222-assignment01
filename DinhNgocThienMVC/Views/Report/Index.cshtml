@model IEnumerable<Repositories.Models.NewsArticle>

@{
    ViewData["Title"] = "News Article Report";
}

<h2>News Article Statistics Report</h2>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row">
                <div class="col-md-4">
                    <label for="startDate" class="form-label">Start Date</label>
                    <input type="date" id="startDate" name="startDate" class="form-control" 
                           value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label for="endDate" class="form-label">End Date</label>
                    <input type="date" id="endDate" name="endDate" class="form-control" 
                           value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary d-block">Generate Report</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.StartDate != null && ViewBag.EndDate != null)
{
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Report Results</h5>
            <small class="text-muted">
                Period: @((DateTime)ViewBag.StartDate).ToString("MMMM dd, yyyy") to @((DateTime)ViewBag.EndDate).ToString("MMMM dd, yyyy")
            </small>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="alert alert-info">
                    <strong>Total Articles:</strong> @Model.Count()
                </div>

                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Article ID</th>
                            <th>Headline</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Created By</th>
                            <th>Created Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var article in Model)
                        {
                            <tr>
                                <td>@article.NewsArticleID</td>
                                <td>@article.Headline</td>
                                <td>@article.NewsTitle</td>
                                <td>@(article.Category?.CategoryName ?? "N/A")</td>
                                <td>@(article.CreatedBy?.AccountName ?? "N/A")</td>
                                <td>@(article.CreatedDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                <td>
                                    @if (article.NewsStatus == true)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-warning">
                    <p>No articles found for the selected date range.</p>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <p>Please select a start date and end date to generate a report.</p>
    </div>
}
