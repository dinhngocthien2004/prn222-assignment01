@model IEnumerable<Repositories.Models.SystemAccount>

@{
    ViewData["Title"] = "Account Management";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

<style>
    h2 {
        font-weight: 700;
        color: #2b3e50;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    h2 i {
        color: #007bff;
    }

    .btn-gradient {
        background: linear-gradient(90deg, #007bff, #00c6ff);
        border: none;
        transition: all 0.3s ease;
        font-weight: 600;
    }

    .btn-gradient:hover {
        background: linear-gradient(90deg, #0056b3, #0096ff);
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0, 123, 255, 0.4);
    }

    .table {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .table th {
        background-color: #f0f5ff;
        color: #1e3d59;
        font-weight: 600;
    }

    .table-hover tbody tr:hover {
        background-color: #e8f3ff;
        transition: 0.2s ease;
    }

    .btn-warning, .btn-danger {
        transition: all 0.3s ease;
        border: none;
        font-weight: 500;
    }

    .btn-warning:hover {
        transform: scale(1.05);
        box-shadow: 0 2px 6px rgba(255,193,7,0.4);
    }

    .btn-danger:hover {
        transform: scale(1.05);
        box-shadow: 0 2px 6px rgba(220,53,69,0.4);
    }

    .search-box {
        position: relative;
    }

    .search-box input {
        padding-left: 35px;
        border-radius: 10px;
    }

    .search-box i {
        position: absolute;
        top: 50%;
        left: 10px;
        transform: translateY(-50%);
        color: #888;
    }
</style>

<h2><i class="bi bi-people-fill"></i> Account Management</h2>

<div class="row mb-4 align-items-center">
    <div class="col-md-6 mb-2">
        <button type="button" class="btn btn-gradient" onclick="openCreateModal()">
            <i class="bi bi-person-plus"></i> Create New Account
        </button>
    </div>
    <div class="col-md-6">
        <form method="get" class="d-flex justify-content-end">
            <div class="search-box w-75">
                <i class="bi bi-search"></i>
                <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by name or email..." />
            </div>
        </form>
    </div>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Account ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var account in Model)
        {
            <tr>
                <td>@account.AccountID</td>
                <td>@account.AccountName</td>
                <td>@account.AccountEmail</td>
                <td>
                    @switch (account.AccountRole)
                    {
                        case 1:
                            <span class="badge bg-success">Staff</span>
                            break;
                        case 2:
                            <span class="badge bg-info text-dark">Lecturer</span>
                            break;
                        default:
                            <span class="badge bg-secondary">Unknown</span>
                            break;
                    }
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-warning me-2" onclick="openEditModal(@account.AccountID)">
                        <i class="bi bi-pencil-square"></i> Edit
                    </button>
                    <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@account.AccountID)">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Modal -->
<div class="modal fade" id="accountModal" tabindex="-1" aria-labelledby="accountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="modalContent">
            <!-- Content will be loaded dynamically -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCreateModal() {
            $.get('@Url.Action("Create", "SystemAccount")', function (data) {
                $('#modalContent').html(data);
                $('#accountModal').modal('show');
            });
        }

        function openEditModal(id) {
            $.get('@Url.Action("Edit", "SystemAccount")?id=' + id, function (data) {
                $('#modalContent').html(data);
                $('#accountModal').modal('show');
            });
        }

        function confirmDelete(id) {
            if (confirm('Are you sure you want to delete this account?')) {
                $.post('@Url.Action("Delete", "SystemAccount")', { id: id }, function (response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                });
            }
        }

        $(document).on('submit', '#accountForm', function (e) {
            e.preventDefault();
            var form = $(this);
            $.ajax({
                type: form.attr('method'),
                url: form.attr('action'),
                data: form.serialize(),
                success: function (response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        $('#modalContent').html(response);
                    }
                }
            });
        });
    </script>
}
